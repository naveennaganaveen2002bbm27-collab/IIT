class Solution {
public:
    ListNode* reverseKGroup(ListNode* head, int k) {
        if (!head || k == 1) return head;

        ListNode dummy(0);
        dummy.next = head;
        ListNode *curr = &dummy, *next = &dummy, *prev = &dummy;
        
        // Count total nodes
        int count = 0;
        while (curr->next) {
            curr = curr->next;
            count++;
        }

        // Loop through the list in groups of k
        while (count >= k) {
            curr = prev->next;
            next = curr->next;
            // Standard linked list reversal for k-1 edges
            for (int i = 1; i < k; i++) {
                curr->next = next->next;
                next->next = prev->next;
                prev->next = next;
                next = curr->next;
            }
            prev = curr;
            count -= k;
        }
        return dummy.next;
    }
};
